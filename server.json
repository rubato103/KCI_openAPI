{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.rubato103/kci-openapi-mcp",
  "description": "KCI (Korea Citation Index) literature & citation search via REST Open API + OAI-PMH",
  "version": "0.1.0",
  "repository": {
    "url": "https://github.com/rubato103/KCI_openAPI",
    "source": "github"
  },
  "websiteUrl": "https://github.com/rubato103/KCI_openAPI",
  "packages": [
    {
      "registryType": "mcpb",
      "identifier": "https://github.com/rubato103/KCI_openAPI/releases/download/v0.1.0/kci-openapi-mcp.mcpb",
      "version": "0.1.0",
      "transport": { "type": "stdio" },
      "fileSha256": "__MCPB_SHA256__",
      "environmentVariables": [
        {
          "name": "KCI_API_KEY",
          "description": "KCI REST Open API key (issued at open.kci.go.kr). Not needed for OAI-PMH harvesting.",
          "isRequired": false,
          "isSecret": true,
          "format": "string"
        }
      ]
    }
  ]
}
